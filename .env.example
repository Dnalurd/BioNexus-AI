# BioNexus AI - Environment Configuration Template

# ==========================================
# APPLICATION SETTINGS
# ==========================================
APP_NAME=BioNexus AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=DEBUG

# ==========================================
# SERVER CONFIGURATION
# ==========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
MOBILE_URL=http://localhost:19000

# ==========================================
# SECURITY SETTINGS
# ==========================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:19000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DATABASE_URL=postgresql://biouser:biopass@localhost:5432/bionexus_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_PRE_PING=true
DATABASE_ECHO=false  # Set to true for SQL logging

# ==========================================
# REDIS CONFIGURATION
# ==========================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# CELERY CONFIGURATION
# ==========================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=UTC

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_NAME=BioNexus AI
MAIL_FROM_EMAIL=noreply@bionexus-ai.com

# ==========================================
# FILE STORAGE
# ==========================================
STORAGE_TYPE=local  # local, s3, azure, gcs
STORAGE_PATH=./storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ==========================================
# AI/ML CONFIGURATION
# ==========================================
LLM_PROVIDER=openai  # openai, anthropic, huggingface
LLM_API_KEY=
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# ==========================================
# ENCRYPTION CONFIGURATION
# ==========================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-change-in-production

# ==========================================
# EXTERNAL SERVICES
# ==========================================
# Sentry Error Tracking
SENTRY_DSN=

# Datadog Monitoring
DATADOG_API_KEY=
DATADOG_APP_KEY=

# ==========================================
# AUDIT & LOGGING
# ==========================================
AUDIT_LOG_ENABLED=true
ACCESS_LOG_ENABLED=true
LOG_FORMAT=json  # json or text

# ==========================================
# ORGANIZATION SETTINGS
# ==========================================
ORGANIZATION_NAME=BioNexus Health
ORGANIZATION_TIMEZONE=UTC
ORGANIZATION_COUNTRY=US

# ==========================================
# FEATURE FLAGS
# ==========================================
FEATURE_AI_ENABLED=true
FEATURE_RESEARCH_MODULE_ENABLED=true
FEATURE_PUBLIC_HEALTH_MODULE_ENABLED=true
FEATURE_MOBILE_APP_ENABLED=true

# ==========================================
# PAGINATION & LIMITS
# ==========================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
MAX_UPLOAD_SIZE=52428800  # 50 MB in bytes

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ==========================================
# DEVELOPMENT ONLY
# ==========================================
SEED_DATABASE=false
TEST_DATA_ENABLED=false
MOCK_EXTERNAL_SERVICES=false
